# Copy this to .env and fill in your keys

# OpenAI — used for menu analysis, cuisine matching, embeddings
OPENAI_API_KEY=sk-...

# Google Places API — used for restaurant discovery
GOOGLE_PLACES_API_KEY=AIza...

# Yelp Fusion API — fallback restaurant data
YELP_API_KEY=...

# App settings
APP_HOST=0.0.0.0
APP_PORT=8000
DATABASE_URL=sqlite+aiosqlite:///./data/gab.db

# Email (SMTP) — for outreach
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=your@gmail.com
FROM_NAME=GAB Dining Club
